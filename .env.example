# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Dashboard password (regular user access)
DASHBOARD_PASSWORD=your-dashboard-password

# Admin password (admin access + Launch Batch button)
ADMIN_PASSWORD=your-admin-password

# Secret key for signing session cookies (generate a random string)
SECRET_KEY=change-me-to-a-long-random-secret

# HappyRobot API key for fetching transcripts (get it from platform.happyrobot.ai)
HAPPYROBOT_API_KEY=hr_live_your_key_here

# Server port (Railway provides this automatically)
PORT=8000
